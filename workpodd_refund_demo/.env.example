# ShopFlow Workpodd demo — environment variables
# Copy to `.env` in the backend repo root (where manage.py lives) and fill in values:
#   cp workpodd_refund_demo/.env.example .env
#
# Do not commit `.env` with real secrets.

# ==================== GENERAL ====================
env_type=NexaByte

# ==================== AZURE OPENAI (CHAT — REQUIRED) ====================
# Same resource as your main chat deployment (e.g. South India)
AZURE_OPENAI_API_KEY=
LE_OPENAI_BASE=
OPENAI_API_VERSION=2025-01-01-preview

# Chat deployment name in Azure portal (exact name, not model id)
# Use one of:
AZURE_OPENAI_GPT4O=
AZURE_OPENAI_GPT4O_MINI=
LE_OPENAI_GPT4_TURBO=

# Optional: override chat API version
# AZURE_OPENAI_GPT4O_API_VERSION=

# ==================== OPENAI DIRECT (OPTIONAL) ====================
# Alternative to Azure for chat and/or all voice features
LE_OPEN_AI_KEY=

# ==================== VOICE — TTS (OPTIONAL) ====================
# If TTS is on a separate regional Azure resource (e.g. North Central US):
AZURE_OPENAI_TTS_DEPLOYMENT=tts-hd
AZURE_OPENAI_TTS_BASE=
AZURE_OPENAI_TTS_API_KEY=
AZURE_OPENAI_TTS_API_VERSION=2024-03-01-preview
OPENAI_TTS_VOICE=alloy

# ==================== VOICE — WHISPER STT (OPTIONAL) ====================
# Browser speech recognition works without this
AZURE_OPENAI_WHISPER_DEPLOYMENT=
# WHISPER_DEPLOYMENT=
# AZURE_OPENAI_WHISPER_API_VERSION=

# ==================== VOICE — REALTIME LIVE CALL (OPTIONAL) ====================
AZURE_OPENAI_REALTIME_DEPLOYMENT=
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# AZURE_OPENAI_REALTIME_API_VERSION=2024-10-01-preview

# ==================== DJANGO (OPTIONAL) ====================
DEBUG=True
ALLOWED_HOSTS=*
